<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.exercise.ExercisesFragment">

        <TextView
            android:id="@+id/headline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/exercises"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineLarge"
            android:textColor="@color/material_on_background_emphasis_high_type"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:fontFamily="@font/darkcollegefont"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <ScrollView
            android:id="@+id/scrollView2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headline">

            <GridLayout
                android:id="@+id/gridLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true"
                android:padding="8dp"
                >

                <include
                    android:id="@+id/abdominals_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/abdominals}"
                    app:image="@{@drawable/abdominals}"/>

                <include
                    android:id="@+id/biceps_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/biceps}"
                    app:image="@{@drawable/biceps}"/>

                <include
                    android:id="@+id/chest_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/chest}"
                    app:image="@{@drawable/chest}"/>


                <include
                    android:id="@+id/lats_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/lats}"
                    app:image="@{@drawable/lats}"/>

                <include
                    android:id="@+id/middle_back_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/middle_back}"
                    app:image="@{@drawable/middle_back}"/>

                <include
                    android:id="@+id/lower_back_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/lower_back}"
                    app:image="@{@drawable/lower_back}"/>

                <include
                    android:id="@+id/triceps_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/triceps}"
                    app:image="@{@drawable/triceps}"/>

                <include
                    android:id="@+id/quadriceps_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/quadriceps}"
                    app:image="@{@drawable/quadriceps}"/>

                <include
                    android:id="@+id/hamstrings_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/hamstrings}"
                    app:image="@{@drawable/hamstrings}"/>

                <include
                    android:id="@+id/glutes_card"
                    layout="@layout/muscle_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:muscle="@{@string/glutes}"
                    app:image="@{@drawable/glutes}"/>

            </GridLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>