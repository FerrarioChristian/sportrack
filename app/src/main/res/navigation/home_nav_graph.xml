<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_nav_graph"
    app:startDestination="@id/loginFragment">
    <fragment
        android:id="@+id/loginFragment"
        android:name="it.unimib.icasiduso.sportrack.ui.auth.LoginFragment"
        android:label="LoginFragment"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_mainActivityWithBottomNav"
            app:destination="@id/mainActivityWithBottomNav" />
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>
    <activity
        android:id="@+id/mainActivityWithBottomNav"
        android:name="it.unimib.icasiduso.sportrack.main.MainActivityWithBottomNav"
        android:label="activity_main_with_bottom_navigation_view"
        tools:layout="@layout/activity_main_with_bottom_nav" />
    <fragment
        android:id="@+id/registerFragment"
        android:name="it.unimib.icasiduso.sportrack.ui.auth.RegisterFragment"
        android:label="fragment_register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
</navigation>