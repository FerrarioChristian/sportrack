<?xml version="1.0" encoding="utf-8"?>

<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/exercises"
    app:startDestination="@id/exercisesFragment">
    <argument
        android:name="id"
        android:defaultValue="0L"
        app:argType="long" />

    <fragment
        android:id="@+id/exercisesFragment"
        android:name="it.unimib.icasiduso.sportrack.ui.exercise.ExercisesFragment"
        android:label="fragment_exercises"
        tools:layout="@layout/fragment_exercises">
        <argument
            android:name="id"
            android:defaultValue="0L"
            app:argType="long" />
        <action
            android:id="@+id/action_exercisesFragment_to_listExercisesFragment"
            app:destination="@id/listExercisesFragment" />
    </fragment>
    <fragment
        android:id="@+id/listExercisesFragment"
        android:name="it.unimib.icasiduso.sportrack.ui.exercise.ListExercisesFragment"
        android:label="ListExercisesFragment">
        <argument
            android:name="id"
            app:argType="java.lang.Long" />
        <argument
            android:name="muscle"
            app:argType="java.lang.String" />

        <action
            android:id="@+id/action_listExercisesFragment_to_exerciseDetails"
            app:destination="@id/exerciseDetails" />
    </fragment>
    <fragment
        android:id="@+id/exerciseDetails"
        android:name="it.unimib.icasiduso.sportrack.ui.exercise.ExerciseDetailsFragment"
        android:label="ExerciseDetails">
        <argument
            android:name="id"
            app:argType="java.lang.Long" />
        <argument
            android:name="exercise"
            app:argType="it.unimib.icasiduso.sportrack.model.exercise.Exercise" />
    </fragment>
    <action
        android:id="@+id/action_global_exercisesFragment"
        app:destination="@id/exercisesFragment" />
</navigation>